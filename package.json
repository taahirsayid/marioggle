{
  "name": "marioggle",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build -w @marioggle/shared && npm run build -w @marioggle/engine && npm run build -w @marioggle/web && npm run build -w @marioggle/server",
    "build:web": "npm run build -w @marioggle/web",
    "build:preset-grids": "node scripts/build-preset-grids-standalone.js",
    "dev": "concurrently \"npm run dev -w @marioggle/server\" \"npm run dev -w @marioggle/web\"",
    "test": "npm run test -w @marioggle/engine && npm run test -w @marioggle/shared",
    "build:dictionary": "node scripts/build-dictionary.mjs",
    "start": "npm run start -w @marioggle/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "wordnet-db": "^3.1.14"
  }
}
